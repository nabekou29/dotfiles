{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "cleanupPeriodDays": 90,
  "env": {
    "EDITOR": "nvim",
    "CLAUDE_CODE_NO_FLICKER": "1"
  },
  "permissions": {
    "allow": [
      "Bash(cat:*)",
      "Bash(gh pr diff:*)",
      "Bash(gh pr view:*)",
      "Bash(gh search:*)",
      "Bash(git add:*)",
      "Bash(ls:*)",
      "Bash(mkdir:*)",
      "Bash(rg:*)",
      "Bash(wc:*)",
      "WebSearch"
    ],
    "deny": [
      "Bash(curl:*)",
      "Bash(mongod:*)",
      "Bash(mysql:*)",
      "Bash(psql:*)",
      "Bash(sudo:*)",
      "Bash(wget:*)",
      "Read(.env,*)",
      "Read(id_ed25519)",
      "Read(id_rsa)",
      "Write(**/secrets/**)",
      "Write(.env*)"
    ],
    "ask": [
      "mcp__claude_ai_Notion__notion-update-page",
      "mcp__claude_ai_Notion__notion-create-pages",
      "mcp__claude_ai_Notion__notion-create-comment",
      "mcp__claude_ai_Notion__notion-create-database",
      "mcp__claude_ai_Notion__notion-duplicate-page",
      "mcp__claude_ai_Notion__notion-move-pages",
      "mcp__claude_ai_Notion__notion-update-data-source"
    ],
    "defaultMode": "bypassPermissions"
  },
  "model": "sonnet",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_CONFIG_DIR\"/_scripts/validate-bash.sh"
          }
        ]
      },
      {
        "matcher": "EnterWorktree|ExitWorktree",
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_CONFIG_DIR\"/_scripts/deny-builtin-worktree.sh"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_CONFIG_DIR\"/_scripts/trev-reveal.sh"
          }
        ]
      }
    ],
    "Notification": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_CONFIG_DIR\"/_scripts/notification.sh"
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "\"$CLAUDE_CONFIG_DIR\"/_scripts/statusline.sh",
    "padding": 1
  },
  "enabledPlugins": {
    "agent-sdk-dev@claude-code-plugins": true,
    "code-review@claude-code-plugins": true,
    "code-simplifier@claude-plugins-official": true,
    "context7@claude-plugins-official": true,
    "gopls-lsp@claude-plugins-official": true,
    "lua-lsp@claude-plugins-official": true,
    "playwright@claude-plugins-official": false,
    "rust-analyzer-lsp@claude-plugins-official": true,
    "typescript-lsp@claude-plugins-official": true,
    "slack@claude-plugins-official": true,
    "codex@openai-codex": true
  },
  "extraKnownMarketplaces": {
    "openai-codex": {
      "source": {
        "source": "github",
        "repo": "openai/codex-plugin-cc"
      }
    }
  },
  "language": "日本語",
  "alwaysThinkingEnabled": true,
  "effortLevel": "high",
  "autoUpdatesChannel": "latest",
  "autoMemoryEnabled": false,
  "autoDreamEnabled": false,
  "skipDangerousModePermissionPrompt": true,
  "feedbackSurveyState": {
    "lastShownTime": 1754280246185
  }
}
