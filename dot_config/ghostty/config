term = ghostty
macos-option-as-alt = true
shell-integration = zsh

theme = Iceberg Dark

background-opacity = 0.93
background-blur-radius = 10
resize-overlay = never

font-family = Moralerspace Krypton
font-size = 14
font-thicken = true

font-feature = ss01
font-feature = ss02
font-feature = ss03
font-feature = ss04
font-feature = ss05
font-feature = ss06
font-feature = ss07
font-feature = ss08
font-feature = ss09
font-feature = cv01
font-feature = cv10
font-feature = cv11
font-feature = cv31
font-feature = cv32
font-feature = -dlig

macos-titlebar-style = hidden

mouse-hide-while-typing = true
