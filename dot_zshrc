# push-line: йЂЂйЃїгЃ—гЃџг‚ігѓћгѓігѓ‰г‚’гѓ—гѓ­гѓігѓ—гѓ€гЃ«иЎЁз¤єгЃ™г‚‹
_push-line-with-display() {
  _PUSHED_LINE="$BUFFER"
  PS1="%F{yellow}вЏЋ ${BUFFER//\%/%%}%f"$'\n'"$PS1"
  zle push-line
  zle reset-prompt
}
