# в”Ђв”Ђ Prompt в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
omp-prompt() {
    local config_dir="$XDG_CONFIG_HOME/oh-my-posh"
    case "$1" in
        minimal) eval "$(oh-my-posh init zsh --config "$config_dir/config-minimal.omp.toml")" ;;
        *)       eval "$(oh-my-posh init zsh --config "$config_dir/config.omp.toml")" ;;
    esac
}
_omp-prompt() {
    local -a options
    options=('default:йЂљеёёгЃ®гѓ—гѓ­гѓігѓ—гѓ€' 'minimal:г‚·гѓігѓ—гѓ«гЃЄгѓ—гѓ­гѓігѓ—гѓ€')
    _describe 'prompt' options
}
compdef _omp-prompt omp-prompt

