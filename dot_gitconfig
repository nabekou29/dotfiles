[user]
	name = nabekou29
	email = nabekou0729@gmail.com
[core]
	ignorecase = false
	editor = nvim
	pager = delta
	autocrlf = false
	quotepath = false
	excludessfile = ~/.config/git/ignore
	symlinks = true
	fsmonitor = true
	untrackedcache = true
	fileMode = false
[color]
	ui = true
[interactive]
	diffFilter = delta --color-only
[fetch]
	prune = true
[init]
	defaultBranch = main
[push]
	default = current
[pull]
	rebase = true
[rebase]
	autostash = true
[delta]
	line-numbers = true
[merge]
	conflictstyle = zdiff3
[rerere]
	enabled = true
[diff]
	algorithm = histogram
[filter "lfs"]
	required = true
	clean = git-lfs clean -- %f
	smudge = git-lfs smudge -- %f
	process = git-lfs filter-process
[credential "https://github.com"]
	helper =
	helper = !gh auth git-credential
[credential "https://gist.github.com"]
	helper =
	helper = !gh auth git-credential
[wt]
	basedir = ../{gitroot}-wt
	symlink = .claude/memory/
	symlink = .claude/settings.local.json
	symlink = .claude/tmp/
	symlink = CLAUDE.local.md
	copy = .env*
	copy = .envrc
	copy = .mise.local.toml
	copy = mise.local.toml
	copy = lefthook-local.yml
	copy = .nvim.lua
	copy = codebook.toml
	hook = [ -f mise.toml ] || [ -f .mise.toml ] || [ -f mise.local.toml ] || [ -f .mise.local.toml ] && mise trust && mise install
	hook = [ -f .envrc ] && direnv allow || true
	hook = git-wt-symlink
	remover = trash
